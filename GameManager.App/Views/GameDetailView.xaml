<UserControl x:Class="GameManager.App.Views.GameDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="DetailInfoLabelStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource FormLabelStyle}">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="DetailInfoValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="DetailMiniButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="62" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="DetailDangerMiniButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DetailMiniButtonStyle}">
            <Setter Property="Foreground" Value="#B83A3A" />
            <Setter Property="BorderBrush" Value="#DFAFAF" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <ScrollViewer.Resources>
            <Style TargetType="ScrollBar"
                   BasedOn="{StaticResource ModernScrollBarStyle}" />
        </ScrollViewer.Resources>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource SectionCardStyle}"
                        Padding="0"
                        ClipToBounds="True">
                    <Grid Height="410"
                          Background="{DynamicResource SurfaceBrush}">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="暂无封面"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="16"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="可在修改游戏中添加"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,6,0,0"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <Image Source="{Binding Game.CoverImagePath}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="游戏状态"
                                   Style="{StaticResource SectionTitleStyle}" />

                        <TextBlock Text="累计游玩"
                                   Style="{StaticResource DetailInfoLabelStyle}" />
                        <TextBlock Text="{Binding TotalPlayTimeText}"
                                   Style="{StaticResource DetailInfoValueStyle}" />

                        <Border Height="1"
                                Margin="0,14"
                                Background="{DynamicResource LineBrush}" />

                        <TextBlock Text="上次启动"
                                   Style="{StaticResource DetailInfoLabelStyle}" />
                        <TextBlock Text="{Binding LastLaunchTimeText}"
                                   Style="{StaticResource DetailInfoValueStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Grid Margin="0,0,0,18">
                    <TextBlock Text="游戏操作"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0"
                               VerticalAlignment="Center" />

                    <Button Content="返回游戏库"
                            Command="{Binding BackCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="108"
                            HorizontalAlignment="Right" />
                </Grid>

                <WrapPanel Margin="0,0,0,18">
                    <Button Content="开始游戏"
                            Command="{Binding StartGameCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="132"
                            Margin="0,0,10,10" />
                    <Button Content="备份存档"
                            Command="{Binding BackupSaveCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="112"
                            Margin="0,0,10,10" />
                    <Button Content="选择恢复"
                            Command="{Binding RestoreSaveCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="112"
                            Margin="0,0,10,10" />
                    <Button Content="同步存档"
                            Command="{Binding SyncSaveCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="112"
                            Margin="0,0,10,10" />
                    <Button Content="修改信息"
                            Command="{Binding EditGameCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="104"
                            Margin="0,0,10,10" />
                    <Button Content="打开游戏目录"
                            Command="{Binding OpenGameDirectoryCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="120"
                            Margin="0,0,10,10" />
                    <Button Content="打开存档目录"
                            Command="{Binding OpenSaveDirectoryCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="120"
                            Margin="0,0,10,10" />
                </WrapPanel>

                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource StatusPillStyle}">
                        <StackPanel>
                            <TextBlock Text="启动状态"
                                       Style="{StaticResource DetailInfoLabelStyle}" />
                            <TextBlock Text="{Binding LaunchStatusText}"
                                       Style="{StaticResource DetailInfoValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource StatusPillStyle}">
                        <StackPanel>
                            <TextBlock Text="存档状态"
                                       Style="{StaticResource DetailInfoLabelStyle}" />
                            <TextBlock Text="{Binding SaveBackupStatusText}"
                                       Style="{StaticResource DetailInfoValueStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource StatusPillStyle}"
                        Margin="0,0,0,18">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="云存档状态"
                                       Style="{StaticResource DetailInfoLabelStyle}" />
                            <TextBlock Text="{Binding SyncStatusText}"
                                       Style="{StaticResource DetailInfoValueStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}"
                        Visibility="{Binding HasSyncDecision, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="{Binding SyncDecisionTitle}"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding SyncDecisionDescription}"
                                   Style="{StaticResource MutedTextStyle}"
                                   Margin="0,-6,0,14" />
                        <WrapPanel>
                            <Button Content="{Binding UseLocalActionText}"
                                    Command="{Binding ResolveUseLocalCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="132"
                                    Margin="0,0,10,10" />
                            <Button Content="{Binding UseCloudActionText}"
                                    Command="{Binding ResolveUseCloudCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="104"
                                    Margin="0,0,10,10" />
                            <Button Content="保留两份"
                                    Command="{Binding ResolveKeepBothCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="104"
                                    Margin="0,0,10,10" />
                            <Button Content="稍后处理"
                                    Command="{Binding CancelConflictCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="104"
                                    Margin="0,0,10,10" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="游戏信息"
                                   Style="{StaticResource SectionTitleStyle}" />

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="游戏目录"
                                           Style="{StaticResource DetailInfoLabelStyle}" />
                                <TextBlock Text="{Binding Game.GameRootPath}"
                                           Style="{StaticResource DetailInfoValueStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Game.GameRootPath}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="存档目录"
                                           Style="{StaticResource DetailInfoLabelStyle}" />
                                <TextBlock Text="{Binding Game.SavePath}"
                                           Style="{StaticResource DetailInfoValueStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Game.SavePath}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}"
                        Visibility="{Binding HasExternalMetadata, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="游戏资料"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0" />
                                <TextBlock Text="{Binding ExternalMetadataTitle}"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,5,0,0" />
                            </StackPanel>
                            <WrapPanel Grid.Column="1"
                                       HorizontalAlignment="Right"
                                       Margin="16,0,0,0">
                                <Button Content="刷新"
                                        Command="{Binding RefreshExternalMetadataCommand}"
                                        Style="{StaticResource DetailMiniButtonStyle}"
                                        Margin="0,0,8,0" />
                                <Button Content="来源"
                                        Command="{Binding OpenExternalSourceCommand}"
                                        ToolTip="外部浏览器需要单独登录 Bangumi"
                                        Style="{StaticResource DetailMiniButtonStyle}"
                                        Margin="0,0,8,0" />
                                <Button Content="解除关联"
                                        Command="{Binding UnlinkExternalMetadataCommand}"
                                        Style="{StaticResource DetailDangerMiniButtonStyle}" />
                            </WrapPanel>
                        </Grid>
                        <TextBlock Text="{Binding ExternalMetadataInfo}"
                                   Style="{StaticResource MutedTextStyle}"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="{Binding ExternalMetadataSummaryDisplay}"
                                   Style="{StaticResource DetailInfoValueStyle}"
                                   Margin="0,0,0,10" />
                        <Button Content="{Binding ExternalSummaryToggleText}"
                                Command="{Binding ToggleExternalSummaryCommand}"
                                Style="{StaticResource DetailMiniButtonStyle}"
                                HorizontalAlignment="Left"
                                Margin="0,-2,0,10"
                                Visibility="{Binding CanToggleExternalSummary, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Text="{Binding ExternalMetadataTags}"
                                   Style="{StaticResource MutedTextStyle}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding ExternalMetadataStatusText}"
                                   Style="{StaticResource MutedTextStyle}"
                                   Margin="0,8,0,0" />

                        <Border Style="{StaticResource SettingsOptionRowStyle}"
                                Margin="0,12,0,0"
                                Visibility="{Binding HasExternalMetadataConflict, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{Binding ExternalMetadataConflictText}"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <WrapPanel Margin="0,10,0,0">
                                    <Button Content="保留本机"
                                            Command="{Binding UseLocalExternalMetadataCommand}"
                                            Style="{StaticResource DetailMiniButtonStyle}"
                                            Margin="0,0,8,0" />
                                    <Button Content="采用云端"
                                            Command="{Binding UseCloudExternalMetadataCommand}"
                                            Style="{StaticResource DetailMiniButtonStyle}"
                                            Margin="0,0,8,0" />
                                    <Button Content="解除关联"
                                            Command="{Binding UnlinkConflictingExternalMetadataCommand}"
                                            Style="{StaticResource DetailDangerMiniButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{DynamicResource LineBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="0,16,0,0"
                                Margin="0,16,0,0"
                                Visibility="{Binding HasMetadataRefreshPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="确认资料更新"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding MetadataRefreshDifferences}"
                                           Style="{StaticResource MutedTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                                <WrapPanel Margin="0,10,0,0">
                                    <CheckBox Content="名称"
                                              IsChecked="{Binding RefreshImportName}"
                                              Foreground="{DynamicResource TextBrush}"
                                              Margin="0,0,16,8" />
                                    <CheckBox Content="封面"
                                              IsChecked="{Binding RefreshImportCover}"
                                              Foreground="{DynamicResource TextBrush}"
                                              Margin="0,0,16,8" />
                                    <CheckBox Content="简介"
                                              IsChecked="{Binding RefreshImportSummary}"
                                              Foreground="{DynamicResource TextBrush}"
                                              Margin="0,0,16,8" />
                                    <CheckBox Content="发行日期"
                                              IsChecked="{Binding RefreshImportReleaseDate}"
                                              Foreground="{DynamicResource TextBrush}"
                                              Margin="0,0,16,8" />
                                    <CheckBox Content="开发商"
                                              IsChecked="{Binding RefreshImportDeveloper}"
                                              Foreground="{DynamicResource TextBrush}"
                                              Margin="0,0,16,8" />
                                    <CheckBox Content="发行商"
                                              IsChecked="{Binding RefreshImportPublisher}"
                                              Foreground="{DynamicResource TextBrush}"
                                              Margin="0,0,16,8" />
                                    <CheckBox Content="标签"
                                              IsChecked="{Binding RefreshImportTags}"
                                              Foreground="{DynamicResource TextBrush}"
                                              Margin="0,0,16,8" />
                                </WrapPanel>
                                <WrapPanel Margin="0,4,0,0">
                                    <Button Content="应用所选字段"
                                            Command="{Binding ApplyExternalMetadataRefreshCommand}"
                                            Style="{StaticResource DetailMiniButtonStyle}"
                                            Margin="0,0,8,0" />
                                    <Button Content="取消"
                                            Command="{Binding CancelExternalMetadataRefreshCommand}"
                                            Style="{StaticResource DetailMiniButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsOptionRowStyle}"
                                Margin="0,16,0,0"
                                Visibility="{Binding ShowBangumiCollection, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="78" />
                                    <ColumnDefinition Width="78" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Bangumi 收藏"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding BangumiCollectionStatusText}"
                                               Style="{StaticResource MutedTextStyle}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding BangumiCollectionOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedBangumiCollectionType}"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Margin="8,0" />
                                <Button Grid.Column="2"
                                        Content="刷新"
                                        Command="{Binding RefreshBangumiCollectionCommand}"
                                        Style="{StaticResource DetailMiniButtonStyle}" />
                                <Button Grid.Column="3"
                                        Content="保存"
                                        Command="{Binding SaveBangumiCollectionCommand}"
                                        Style="{StaticResource DetailMiniButtonStyle}"
                                        Margin="8,0,0,0" />
                                <Grid Grid.Row="1"
                                      Grid.ColumnSpan="4"
                                      Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox ItemsSource="{Binding BangumiRatingOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding BangumiRating}"
                                              Style="{StaticResource ModernComboBoxStyle}" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding BangumiComment, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource TextBoxStyle}"
                                             Margin="10,0,0,0"
                                             ToolTip="Bangumi 短评" />
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}"
                        Margin="0">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="本地备份历史"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0" />
                                <TextBlock Text="按时间查看、恢复或删除当前游戏的本地备份"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource StatusPillStyle}"
                                Visibility="{Binding HasNoSaveBackups, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="暂无本地备份"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <ListView ItemsSource="{Binding SaveBackups}"
                                  MaxHeight="280"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  Visibility="{Binding HasSaveBackups, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.Resources>
                                <Style TargetType="ScrollBar"
                                       BasedOn="{StaticResource ModernScrollBarStyle}" />
                            </ListView.Resources>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Focusable" Value="False" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SettingsOptionRowStyle}"
                                            Margin="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="142" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding CreatedAtText}"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding FileName}"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           FontSize="12"
                                                           Margin="0,3,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding FileName}" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SizeText}"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       VerticalAlignment="Center" />

                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right">
                                                <Button Content="恢复"
                                                        Command="{Binding DataContext.RestoreBackupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource DetailMiniButtonStyle}"
                                                        Margin="0,0,8,0" />
                                                <Button Content="删除"
                                                        Command="{Binding DataContext.DeleteBackupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource DetailDangerMiniButtonStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
