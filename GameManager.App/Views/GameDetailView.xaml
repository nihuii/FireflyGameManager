<UserControl x:Class="GameManager.App.Views.GameDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="DetailInfoLabelStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource FormLabelStyle}">
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="DetailInfoValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="DetailMiniButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="62" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="DetailDangerMiniButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DetailMiniButtonStyle}">
            <Setter Property="Foreground" Value="#B83A3A" />
            <Setter Property="BorderBrush" Value="#DFAFAF" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <ScrollViewer.Resources>
            <Style TargetType="ScrollBar"
                   BasedOn="{StaticResource ModernScrollBarStyle}" />
        </ScrollViewer.Resources>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource SectionCardStyle}"
                        Padding="0"
                        ClipToBounds="True">
                    <Grid Height="410"
                          Background="{DynamicResource SurfaceBrush}">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="暂无封面"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       FontSize="16"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="可在修改游戏中添加"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,6,0,0"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <Image Source="{Binding Game.CoverImagePath}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="游戏状态"
                                   Style="{StaticResource SectionTitleStyle}" />

                        <TextBlock Text="累计游玩"
                                   Style="{StaticResource DetailInfoLabelStyle}" />
                        <TextBlock Text="{Binding TotalPlayTimeText}"
                                   Style="{StaticResource DetailInfoValueStyle}" />

                        <Border Height="1"
                                Margin="0,14"
                                Background="{DynamicResource LineBrush}" />

                        <TextBlock Text="上次启动"
                                   Style="{StaticResource DetailInfoLabelStyle}" />
                        <TextBlock Text="{Binding LastLaunchTimeText}"
                                   Style="{StaticResource DetailInfoValueStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Grid Margin="0,0,0,18">
                    <TextBlock Text="游戏操作"
                               Style="{StaticResource SectionTitleStyle}"
                               Margin="0"
                               VerticalAlignment="Center" />

                    <Button Content="返回游戏库"
                            Command="{Binding BackCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="108"
                            HorizontalAlignment="Right" />
                </Grid>

                <WrapPanel Margin="0,0,0,18">
                    <Button Content="开始游戏"
                            Command="{Binding StartGameCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="132"
                            Margin="0,0,10,10" />
                    <Button Content="备份存档"
                            Command="{Binding BackupSaveCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="112"
                            Margin="0,0,10,10" />
                    <Button Content="选择恢复"
                            Command="{Binding RestoreSaveCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="112"
                            Margin="0,0,10,10" />
                </WrapPanel>

                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource StatusPillStyle}">
                        <StackPanel>
                            <TextBlock Text="启动状态"
                                       Style="{StaticResource DetailInfoLabelStyle}" />
                            <TextBlock Text="{Binding LaunchStatusText}"
                                       Style="{StaticResource DetailInfoValueStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource StatusPillStyle}">
                        <StackPanel>
                            <TextBlock Text="存档状态"
                                       Style="{StaticResource DetailInfoLabelStyle}" />
                            <TextBlock Text="{Binding SaveBackupStatusText}"
                                       Style="{StaticResource DetailInfoValueStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="游戏信息"
                                   Style="{StaticResource SectionTitleStyle}" />

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="游戏目录"
                                           Style="{StaticResource DetailInfoLabelStyle}" />
                                <TextBlock Text="{Binding Game.GameRootPath}"
                                           Style="{StaticResource DetailInfoValueStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Game.GameRootPath}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="存档目录"
                                           Style="{StaticResource DetailInfoLabelStyle}" />
                                <TextBlock Text="{Binding Game.SavePath}"
                                           Style="{StaticResource DetailInfoValueStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Game.SavePath}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardStyle}"
                        Margin="0">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="本地备份历史"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0" />
                                <TextBlock Text="按时间查看、恢复或删除当前游戏的本地备份"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource StatusPillStyle}"
                                Visibility="{Binding HasNoSaveBackups, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="暂无本地备份"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       HorizontalAlignment="Center" />
                        </Border>

                        <ListView ItemsSource="{Binding SaveBackups}"
                                  MaxHeight="280"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  Visibility="{Binding HasSaveBackups, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.Resources>
                                <Style TargetType="ScrollBar"
                                       BasedOn="{StaticResource ModernScrollBarStyle}" />
                            </ListView.Resources>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Focusable" Value="False" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SettingsOptionRowStyle}"
                                            Margin="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="142" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding CreatedAtText}"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding FileName}"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           FontSize="12"
                                                           Margin="0,3,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding FileName}" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SizeText}"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       VerticalAlignment="Center" />

                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right">
                                                <Button Content="恢复"
                                                        Command="{Binding DataContext.RestoreBackupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource DetailMiniButtonStyle}"
                                                        Margin="0,0,8,0" />
                                                <Button Content="删除"
                                                        Command="{Binding DataContext.DeleteBackupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource DetailDangerMiniButtonStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
