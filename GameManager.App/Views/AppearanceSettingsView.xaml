<UserControl x:Class="GameManager.App.Views.AppearanceSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style TargetType="ScrollBar"
               BasedOn="{StaticResource ModernScrollBarStyle}" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="SettingsOverview"
                      Grid.Row="0"
                      HorizontalContentAlignment="Stretch"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsOverviewSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Margin="0,0,12,0">
                <TextBlock Text="设置中心" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="按使用场景整理设置项，进入分类后再调整具体选项。"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="0,-8,0,18" />

                <Button Command="{Binding ShowSectionCommand}"
                        CommandParameter="General"
                        Style="{StaticResource SettingsSectionButtonStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="常规"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="开机启动、关闭窗口、语言和上次页面。"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,5,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text=">"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="20"
                                   VerticalAlignment="Center"
                                   Margin="18,0,0,0" />
                    </Grid>
                </Button>

                <Button Command="{Binding ShowSectionCommand}"
                        CommandParameter="Launch"
                        Style="{StaticResource SettingsSectionButtonStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="游戏启动"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="启动游戏前后 Firefly 的窗口行为和自动备份。"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,5,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text=">"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="20"
                                   VerticalAlignment="Center"
                                   Margin="18,0,0,0" />
                    </Grid>
                </Button>

                <Button Command="{Binding ShowSectionCommand}"
                        CommandParameter="Library"
                        Style="{StaticResource SettingsSectionButtonStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="游戏库"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="排序、卡片尺寸、游玩时长显示和本地扫描。"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,5,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text=">"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="20"
                                   VerticalAlignment="Center"
                                   Margin="18,0,0,0" />
                    </Grid>
                </Button>

                <Button Command="{Binding ShowSectionCommand}"
                        CommandParameter="Appearance"
                        Style="{StaticResource SettingsSectionButtonStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="外观"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="壁纸、透明化和随壁纸自适应的界面配色。"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,5,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text=">"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="20"
                                   VerticalAlignment="Center"
                                   Margin="18,0,0,0" />
                    </Grid>
                </Button>

                <Button Command="{Binding ShowSectionCommand}"
                        CommandParameter="Data"
                        Style="{StaticResource SettingsSectionButtonStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="数据与维护"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="打开数据目录、导入导出、清理缓存和重置设置。"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,5,0,0" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text=">"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   FontSize="20"
                                   VerticalAlignment="Center"
                                   Margin="18,0,0,0" />
                    </Grid>
                </Button>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="GeneralSettingsSection"
                      Grid.Row="0"
                      HorizontalContentAlignment="Stretch"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsGeneralSectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Margin="0,0,12,0">
                <DockPanel Margin="0,0,0,16">
                    <Button Content="返回设置"
                            Command="{Binding ShowOverviewCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="96"
                            DockPanel.Dock="Left"
                            Margin="0,0,14,0" />
                    <TextBlock Text="常规" Style="{StaticResource SectionTitleStyle}" Margin="0,7,0,0" />
                </DockPanel>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsOptionRowStyle}">
                            <Grid>
                                <TextBlock Text="开机启动" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                                <CheckBox IsChecked="{Binding StartWithWindows}"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          HorizontalAlignment="Right" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource SettingsOptionRowStyle}">
                            <Grid>
                                <TextBlock Text="启动时最小化" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                                <CheckBox IsChecked="{Binding StartMinimized}"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          HorizontalAlignment="Right" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource SettingsOptionRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="关闭窗口时" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding CloseBehaviorOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding CloseBehavior}"
                                          Style="{StaticResource ModernComboBoxStyle}" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource SettingsOptionRowStyle}">
                            <Grid>
                                <TextBlock Text="记住上次页面" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                                <CheckBox IsChecked="{Binding RememberLastPage}"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          HorizontalAlignment="Right" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource SettingsOptionRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="语言" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding LanguageOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding Language}"
                                          Style="{StaticResource ModernComboBoxStyle}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="LaunchSettingsSection"
                      Grid.Row="0"
                      HorizontalContentAlignment="Stretch"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsLaunchSectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Margin="0,0,12,0">
                <DockPanel Margin="0,0,0,16">
                    <Button Content="返回设置"
                            Command="{Binding ShowOverviewCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="96"
                            DockPanel.Dock="Left"
                            Margin="0,0,14,0" />
                    <TextBlock Text="游戏启动" Style="{StaticResource SectionTitleStyle}" Margin="0,7,0,0" />
                </DockPanel>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsOptionRowStyle}">
                            <Grid>
                                <TextBlock Text="启动游戏后最小化 Firefly" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                                <CheckBox IsChecked="{Binding MinimizeAfterGameLaunch}"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          HorizontalAlignment="Right" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource SettingsOptionRowStyle}">
                            <Grid>
                                <TextBlock Text="游戏退出后恢复窗口" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                                <CheckBox IsChecked="{Binding RestoreAfterGameExit}"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          HorizontalAlignment="Right" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource SettingsOptionRowStyle}">
                            <Grid>
                                <TextBlock Text="启动游戏前自动备份存档" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                                <CheckBox IsChecked="{Binding BackupBeforeGameLaunch}"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          HorizontalAlignment="Right" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="LibrarySettingsSection"
                      Grid.Row="0"
                      HorizontalContentAlignment="Stretch"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsLibrarySectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Margin="0,0,12,0">
                <DockPanel Margin="0,0,0,16">
                    <Button Content="返回设置"
                            Command="{Binding ShowOverviewCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="96"
                            DockPanel.Dock="Left"
                            Margin="0,0,14,0" />
                    <TextBlock Text="游戏库" Style="{StaticResource SectionTitleStyle}" Margin="0,7,0,0" />
                </DockPanel>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <Border Style="{StaticResource SettingsOptionRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="默认排序" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding SortOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding DefaultSort}"
                                          Style="{StaticResource ModernComboBoxStyle}" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource SettingsOptionRowStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="游戏卡片大小" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding CardSizeOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding CardSize}"
                                          Style="{StaticResource ModernComboBoxStyle}" />
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource SettingsOptionRowStyle}">
                            <Grid>
                                <TextBlock Text="在卡片上显示游玩时长" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center" />
                                <CheckBox IsChecked="{Binding ShowPlayTimeOnCards}"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          HorizontalAlignment="Right" />
                            </Grid>
                        </Border>

                        <TextBlock Text="扫描目录" Style="{StaticResource FormLabelStyle}" Margin="2,8,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="104" />
                                <ColumnDefinition Width="104" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding ScanDirectory, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Style="{StaticResource TextBoxStyle}" />
                            <Button Grid.Column="1"
                                    Content="选择目录"
                                    Command="{Binding BrowseScanDirectoryCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="10,0,0,0" />
                            <Button Grid.Column="2"
                                    Content="扫描游戏"
                                    Command="{Binding ScanGamesCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="10,0,0,0" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="AppearanceSettingsSection"
                      Grid.Row="0"
                      HorizontalContentAlignment="Stretch"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsAppearanceSectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Margin="0,0,12,0">
                <DockPanel Margin="0,0,0,16">
                    <Button Content="返回设置"
                            Command="{Binding ShowOverviewCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="96"
                            DockPanel.Dock="Left"
                            Margin="0,0,14,0" />
                    <TextBlock Text="外观" Style="{StaticResource SectionTitleStyle}" Margin="0,7,0,0" />
                </DockPanel>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <Border Height="220"
                                Background="{DynamicResource AppBackgroundBrush}"
                                BorderBrush="{DynamicResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <Grid>
                                <TextBlock Text="壁纸预览"
                                           Style="{StaticResource MutedTextStyle}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                                <Image Source="{Binding WallpaperPath}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Grid>
                        </Border>
                        <TextBlock Text="{Binding WallpaperPathDisplay}"
                                   Style="{StaticResource MutedTextStyle}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,10,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="104" />
                                <ColumnDefinition Width="104" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Content="选择壁纸"
                                    Command="{Binding SelectWallpaperCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                            <Button Grid.Column="1"
                                    Content="移除壁纸"
                                    Command="{Binding ClearWallpaperCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="10,0,0,0" />
                            <TextBlock Grid.Column="2"
                                       Text="透明界面"
                                       Foreground="{DynamicResource TextBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,14,0" />
                            <CheckBox Grid.Column="3"
                                      IsChecked="{Binding IsTransparentUi}"
                                      Style="{StaticResource ToggleSwitchStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <ScrollViewer x:Name="DataSettingsSection"
                      Grid.Row="0"
                      HorizontalContentAlignment="Stretch"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsDataSectionSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Margin="0,0,12,0">
                <DockPanel Margin="0,0,0,16">
                    <Button Content="返回设置"
                            Command="{Binding ShowOverviewCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="96"
                            DockPanel.Dock="Left"
                            Margin="0,0,14,0" />
                    <TextBlock Text="数据与维护" Style="{StaticResource SectionTitleStyle}" Margin="0,7,0,0" />
                </DockPanel>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding DataDirectory}"
                                   Style="{StaticResource MutedTextStyle}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,14" />
                        <WrapPanel>
                            <Button Content="打开数据目录"
                                    Command="{Binding OpenDataDirectoryCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,10,10" />
                            <Button Content="导出全部数据"
                                    Command="{Binding ExportDataCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,10,10" />
                            <Button Content="导入本地数据"
                                    Command="{Binding ImportDataCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,10,10" />
                            <Button Content="清理无效备份"
                                    Command="{Binding ClearInvalidBackupsCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,10,10" />
                            <Button Content="清理封面缓存"
                                    Command="{Binding ClearCoverCacheCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,10,10" />
                            <Button Content="重置全部设置"
                                    Command="{Binding ResetAllSettingsCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,10,10" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Style="{StaticResource StatusPillStyle}"
                Margin="0,12,0,0">
            <DockPanel LastChildFill="True">
                <Button Content="返回游戏库"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Width="112"
                        DockPanel.Dock="Right"
                        Margin="14,0,0,0" />
                <TextBlock Text="{Binding StatusText}"
                           Style="{StaticResource MutedTextStyle}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
