<Window x:Class="GameManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:GameManager.App.Views"
        xmlns:vm="clr-namespace:GameManager.App.ViewModels"
        mc:Ignorable="d"
        Title="Firefly Game Manager"
        Icon="/Assets/Icons/desktop_icon.png"
        Height="720"
        Width="1120"
        MinHeight="620"
        MinWidth="920"
        WindowStyle="None"
        BorderThickness="0"
        Background="Transparent"
        StateChanged="MainWindow_StateChanged"
        Loaded="MainWindow_Loaded"
        Closing="MainWindow_Closing"
        Closed="MainWindow_Closed">
    <WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="12"
                            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DataTemplate DataType="{x:Type vm:GameLibraryViewModel}">
            <views:GameLibraryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GameDetailViewModel}">
            <views:GameDetailView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AddGameViewModel}">
            <views:AddGameView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ManageGameLibraryViewModel}">
            <views:ManageGameLibraryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WebDavSettingsViewModel}">
            <views:WebDavSettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AppearanceSettingsViewModel}">
            <views:AppearanceSettingsView />
        </DataTemplate>
    </Window.Resources>

    <Border x:Name="WindowFrame"
            CornerRadius="12"
            BorderBrush="{DynamicResource LineBrush}"
            BorderThickness="1"
            Background="{DynamicResource AppBackgroundBrush}"
            ClipToBounds="True">
        <Grid>
            <Image x:Name="WallpaperLayer"
                   Source="{Binding WallpaperPath}"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <Border Background="{DynamicResource AppBackgroundBrush}" />

            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="CustomTitleBar"
                    Grid.Row="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="CustomTitleBar_MouseLeftButtonDown">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="MinimizeButton"
                                ToolTip="最小化"
                                Style="{StaticResource WindowControlButtonStyle}"
                                Click="MinimizeButton_Click">
                            <Viewbox Width="12" Height="12">
                                <Path x:Name="MinimizeGlyph"
                                      Data="M 1,6 L 11,6"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.4"
                                      StrokeStartLineCap="Square"
                                      StrokeEndLineCap="Square" />
                            </Viewbox>
                        </Button>
                        <Button x:Name="MaximizeButton"
                                ToolTip="最大化"
                                Style="{StaticResource WindowControlButtonStyle}"
                                Click="MaximizeButton_Click">
                            <Viewbox Width="12" Height="12">
                                <Path x:Name="MaximizeGlyph"
                                      Data="M 1.5,1.5 L 10.5,1.5 L 10.5,10.5 L 1.5,10.5 Z"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.2"
                                      StrokeLineJoin="Miter" />
                            </Viewbox>
                        </Button>
                        <Button x:Name="CloseButton"
                                ToolTip="关闭"
                                Style="{StaticResource CloseWindowButtonStyle}"
                                Click="CloseButton_Click">
                            <Viewbox Width="12" Height="12">
                                <Path x:Name="CloseGlyph"
                                      Data="M 1.5,1.5 L 10.5,10.5 M 10.5,1.5 L 1.5,10.5"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.35"
                                      StrokeStartLineCap="Square"
                                      StrokeEndLineCap="Square" />
                            </Viewbox>
                        </Button>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="16,0,0,0">
                        <Image x:Name="AppTitleIcon"
                               Source="/Assets/Icons/desktop_icon.png"
                               Width="24"
                               Height="24"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Margin="0,0,9,0" />
                        <TextBlock Text="Firefly Game Manager"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="112" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="SideNavigationRail"
                        Grid.Column="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource LineBrush}"
                        BorderThickness="0,0,1,0"
                        CornerRadius="0"
                        Padding="12,18,12,12">
                    <StackPanel>
                        <Image x:Name="SideNavigationAppIcon"
                               Source="/Assets/Icons/desktop_icon.png"
                               Width="72"
                               Height="72"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,20" />

                        <Button Command="{Binding ShowLibraryCommand}"
                                Tag="{Binding IsLibraryNavigationSelected}"
                                ToolTip="{Binding LibraryNavigationText}"
                                Style="{StaticResource NavigationButtonStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <Image x:Name="LibraryNavigationIcon"
                                       Source="/Assets/Icons/home_icon.png"
                                       Width="44"
                                       Height="44"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center" />
                                <TextBlock x:Name="LibraryNavigationLabel"
                                           Text="{Binding LibraryNavigationText}"
                                           Visibility="{Binding IsLibraryNavigationSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,4,0,0"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ShowSyncCommand}"
                                Tag="{Binding IsSyncNavigationSelected}"
                                ToolTip="{Binding SyncNavigationText}"
                                Style="{StaticResource NavigationButtonStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <Image x:Name="SyncNavigationIcon"
                                       Source="/Assets/Icons/synchronize_icon.png"
                                       Width="44"
                                       Height="44"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center" />
                                <TextBlock x:Name="SyncNavigationLabel"
                                           Text="{Binding SyncNavigationText}"
                                           Visibility="{Binding IsSyncNavigationSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,4,0,0"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ShowSettingsCommand}"
                                Tag="{Binding IsSettingsNavigationSelected}"
                                ToolTip="{Binding SettingsNavigationText}"
                                Style="{StaticResource NavigationButtonStyle}">
                            <StackPanel HorizontalAlignment="Center">
                                <Image x:Name="SettingsNavigationIcon"
                                       Source="/Assets/Icons/settings_icon.png"
                                       Width="44"
                                       Height="44"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       HorizontalAlignment="Center" />
                                <TextBlock x:Name="SettingsNavigationLabel"
                                           Text="{Binding SettingsNavigationText}"
                                           Visibility="{Binding IsSettingsNavigationSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,4,0,0"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Grid x:Name="MainContentArea"
                      Grid.Column="1"
                      Margin="18,8,22,22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="64" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding PageTitle}"
                                       Style="{StaticResource ShellTitleStyle}" />
                        </StackPanel>

                        <StackPanel x:Name="PageActionBar"
                                    DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding ShowTopActions, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Button Content="{Binding ManageActionText}"
                                    Command="{Binding ShowManageLibraryCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="92"
                                    Margin="0,0,10,0" />
                            <Button Content="{Binding AddGameActionText}"
                                    Command="{Binding ShowAddGameCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="112" />
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="22">
                        <ContentControl Content="{Binding CurrentViewModel}" />
                    </Border>
                </Grid>
            </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
